{
  "plugin_id": 277653,
  "finding_name": "Remote Services Using Post-Quantum Ciphers",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "testssl.sh --color 0 --groups https://{host}:{port}",
  "timeout_seconds": 60,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "fallback_commands": [
    "nmap -Pn -p {port} --script ssl-enum-ciphers {host} 2>&1"
  ],
  "version_rule": {},
  "validated_if": [
    "mlkem",
    "kyber",
    "x25519kyber768",
    "post-quantum"
  ],
  "validated_if_absent": [],
  "not_validated_if": [],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "failed to resolve",
    "network is unreachable",
    "operation not permitted",
    "cannot create af_netlink socket"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "failed to resolve": "dns_failure",
    "network is unreachable": "host_unreachable",
    "operation not permitted": "inconclusive",
    "cannot create af_netlink socket": "inconclusive"
  },
  "analyst_note": "Confirms the service offers post-quantum key exchange groups (mlkem768x25519, kyber, x25519kyber768). testssl.sh --groups lists supported key exchange groups including PQ hybrids. Detection of mlkem, kyber, or x25519kyber768 in output confirms PQC support. Note: this is an informational finding, not a vulnerability.",
  "references": [
    "https://testssl.sh",
    "https://nmap.org/nsedoc/scripts/ssl-enum-ciphers.html",
    "https://www.nist.gov/cybersecurity/post-quantum-cryptography"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
