{
  "plugin_id": 42873,
  "finding_name": "SSL Medium Strength Cipher Suites Supported (SWEET32)",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "testssl.sh --color 0 --sweet32 https://{host}:{port}",
  "timeout_seconds": 60,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "validated_if": [
    "VULNERABLE"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "not vulnerable"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "could not open a socket",
    "operation not permitted",
    "failed to resolve",
    "0 hosts up",
    "host seems down"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "could not open a socket": "inconclusive",
    "operation not permitted": "inconclusive",
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down"
  },
  "fallback_commands": [
    "sslscan --no-colour --show-ciphers {sslscan_starttls_args} {host}:{port}"
  ],
  "references": [
    "https://testssl.sh",
    "https://sweet32.info/",
    "https://github.com/rbsec/sslscan"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
