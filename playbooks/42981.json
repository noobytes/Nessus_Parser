{
  "plugin_id": 42981,
  "finding_name": "SSL Certificate Expiry - Future Expiry",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "testssl.sh --color 0 -S https://{host}:{port}",
  "timeout_seconds": 45,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "fallback_commands": [
    "openssl s_client -connect {host}:{port} {openssl_tls_args} </dev/null 2>&1 | openssl x509 -noout -dates 2>/dev/null"
  ],
  "version_rule": {},
  "validated_if": [
    "expires",
    "not after",
    "notafter"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "unable to load certificate",
    "could not read certificate"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "temporary failure in name resolution",
    "bio_lookup_ex:system lib",
    "failed to resolve",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "temporary failure in name resolution": "host_down",
    "bio_lookup_ex:system lib": "host_down",
    "failed to resolve": "dns_failure",
    "network is unreachable": "host_unreachable"
  },
  "analyst_note": "Confirms certificate is approaching expiry (within 60 days). testssl.sh -S shows certificate validity dates. The 'expires' or 'not after' output confirms the certificate and its expiry can be read. Manually verify the Not After date is within the warning threshold.",
  "references": [
    "https://testssl.sh",
    "https://docs.openssl.org/3.6/man1/openssl-x509/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
