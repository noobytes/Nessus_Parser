{
  "plugin_id": 50845,
  "finding_name": "OpenSSL Detection",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "openssl s_client -connect {host}:{port} {openssl_tls_args} -brief </dev/null 2>&1",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "fallback_commands": [
    "curl -k -I --silent --show-error --max-time 15 https://{host}:{port}/ 2>&1",
    "nmap -Pn -p {port} --script ssl-cert,banner {host} 2>&1"
  ],
  "version_rule": {},
  "validated_if": [
    "openssl",
    "connection established"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "no peer certificate available",
    "ssl handshake failure"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "temporary failure in name resolution",
    "bio_lookup_ex:system lib",
    "failed to resolve",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "temporary failure in name resolution": "host_down",
    "bio_lookup_ex:system lib": "host_down",
    "failed to resolve": "dns_failure",
    "network is unreachable": "host_unreachable"
  },
  "analyst_note": "Confirms OpenSSL is present on the target service. The TLS handshake succeeds and 'openssl' may appear in the server banner (e.g. Apache/x.y.z OpenSSL/x.y.z). curl -I often reveals the Server header. nmap banner script also extracts server banners.",
  "references": [
    "https://docs.openssl.org/3.6/man1/openssl-s_client/",
    "https://nmap.org/nsedoc/scripts/ssl-cert.html"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
