{
  "plugin_id": 51192,
  "finding_name": "SSL Certificate Cannot Be Trusted",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "testssl.sh --color 0 -S https://{host}:{port}",
  "timeout_seconds": 45,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "validated_if": [
    "Chain of trust",
    "self signed",
    "self-signed",
    "untrusted",
    "verify error:num=",
    "certificate has expired",
    "unable to get local issuer certificate"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "Chain of trust    ok",
    "verification: ok"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "bio_lookup_ex:system lib",
    "temporary failure in name resolution"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "bio_lookup_ex:system lib": "host_down",
    "temporary failure in name resolution": "host_down"
  },
  "fallback_commands": [
    "openssl s_client -connect {host}:{port} {openssl_tls_args} -brief </dev/null"
  ],
  "references": [
    "https://testssl.sh",
    "https://docs.openssl.org/3.6/man1/openssl-s_client/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
