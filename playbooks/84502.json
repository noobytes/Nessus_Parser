{
  "plugin_id": 84502,
  "finding_name": "HSTS Missing From HTTPS Server",
  "service": "https",
  "port_logic": "use_scan_port",
  "command_template": "testssl.sh --color 0 --headers https://{host}:{port}",
  "timeout_seconds": 45,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "validated_if": [
    "not offered"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "max-age"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "could not resolve host",
    "failed to connect",
    "empty reply from server"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "could not resolve host": "host_down",
    "failed to connect": "host_down",
    "empty reply from server": "inconclusive"
  },
  "fallback_commands": [
    "curl -k -I --silent --show-error --max-time 15 https://{host}:{port}/"
  ],
  "version_rule": {},
  "references": [
    "https://testssl.sh",
    "https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Strict-Transport-Security"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
