{
  "plugin_id": 15901,
  "finding_name": "SSL Certificate Expiry",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "testssl.sh --color 0 -S https://{host}:{port}",
  "timeout_seconds": 45,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "fallback_commands": [
    "openssl s_client -connect {host}:{port} {openssl_tls_args} -brief </dev/null 2>&1"
  ],
  "version_rule": {},
  "validated_if": [
    "days ago",
    "certificate has expired",
    "verify error:num=10"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "verification: ok"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "temporary failure in name resolution",
    "bio_lookup_ex:system lib",
    "failed to resolve",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "temporary failure in name resolution": "host_down",
    "bio_lookup_ex:system lib": "host_down",
    "failed to resolve": "dns_failure",
    "network is unreachable": "host_unreachable"
  },
  "references": [
    "https://testssl.sh",
    "https://docs.openssl.org/3.6/man1/openssl-s_client/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
