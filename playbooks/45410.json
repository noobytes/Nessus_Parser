{
  "plugin_id": 45410,
  "finding_name": "SSL Certificate 'commonName' Mismatch",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "openssl s_client -connect {host}:{port} {openssl_tls_args} -verify_hostname {host} -brief </dev/null 2>&1",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "fallback_commands": [
    "sslscan --no-colour --show-certificate {sslscan_starttls_args} {host}:{port} 2>&1"
  ],
  "version_rule": {},
  "validated_if": [
    "hostname mismatch",
    "verify error:num=62",
    "verify error:num=64"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "verification: ok"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "temporary failure in name resolution",
    "bio_lookup_ex:system lib",
    "failed to resolve",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "temporary failure in name resolution": "host_down",
    "bio_lookup_ex:system lib": "host_down",
    "failed to resolve": "dns_failure",
    "network is unreachable": "host_unreachable"
  },
  "analyst_note": "Confirms the certificate CN/SAN does not match the target hostname. openssl -verify_hostname returns error num=62 (hostname mismatch) or num=64 (no matching SAN). Falls back to sslscan --show-certificate to manually inspect Subject and SAN fields.",
  "references": [
    "https://docs.openssl.org/3.6/man1/openssl-s_client/",
    "https://github.com/rbsec/sslscan"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-17"
}
